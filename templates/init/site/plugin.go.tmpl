// Package main is a jughead site plugin generated by `jughead init`.
//
// It exports the well-known `Plugin` symbol the host loader looks up. The site
// is served under {{.SitePath}} and renders a placeholder templ component via
// the Routes callback. Replace the placeholder routes and template with your
// site's implementation.
//
// Build (from this directory, with the same Go toolchain and dependency
// versions as the host):
//
//	CGO_ENABLED=1 go build -buildmode=plugin -o {{.Name}}.so .
//
// Then point JUGHEAD_PLUGINS_DIR at the directory containing the .so and start
// jughead, or iterate standalone with:
//
//	jughead serve ./{{.Name}}.so --port 8080
package main

import (
	"context"
	"io"
	"net/http"

	"github.com/geoffjay/jughead/sdk"

	"github.com/a-h/templ"
	"github.com/gin-gonic/gin"
)

// sitePath is the configured path under which the site is served.
const sitePath = "{{.SitePath}}"

// Plugin is the well-known symbol the host loader looks up.
var Plugin = sdk.Plugin{
	Name: "{{.Name}}",
	Sites: []sdk.Site{
		{
			Path:      sitePath,
			Url:       "https://{{.Name}}.example.com",
			Published: true,
			Theme:     "nord",
			Template:  placeholder(),
			Routes:    Routes,
		},
	},
}

// placeholder is a minimal templ component rendered when the site is browsed
// without its Routes wired. Replace it with your site's layout.
func placeholder() templ.Component {
	return templ.ComponentFunc(func(_ context.Context, w io.Writer) error {
		_, err := io.WriteString(w, "<h1>{{.Name}} site</h1>\n")
		return err
	})
}

// Routes registers the site's handlers onto the provided router group. The
// group's base path is sitePath. Replace these handlers with your site's
// routes.
func Routes(router *gin.RouterGroup, _ string) {
	router.GET("", indexHandler)
	router.GET("/", indexHandler)
}

func indexHandler(c *gin.Context) {
	c.String(http.StatusOK, "{{.Name}} site (replace this with your routes)\n")
}