// Package main is a jughead auth-provider plugin generated by `jughead init`.
//
// It exports the well-known `Plugin` symbol the host loader looks up. The
// provider registers under Name() == "{{.Name}}"; a site references it via
// `Auth.Provider: "{{.Name}}"`. Replace the placeholder Load/instance logic
// with your real auth flow.
//
// Build (from this directory, with the same Go toolchain and dependency
// versions as the host):
//
//	CGO_ENABLED=1 go build -buildmode=plugin -o {{.Name}}.so .
package main

import (
	"errors"
	"net/http"

	"github.com/geoffjay/jughead/sdk"
	sdkauth "github.com/geoffjay/jughead/sdk/auth"
	"github.com/geoffjay/jughead/sessions"

	"github.com/gin-gonic/gin"
)

// Plugin is the well-known symbol the host loader looks up.
var Plugin = sdk.Plugin{
	Name: "{{.Name}}",
	Providers: []sdkauth.Provider{
		{{.TitleName}}Provider{},
	},
}

// {{.TitleName}}Provider implements sdkauth.Provider. Name() is the registry
// key a site references via AuthConfig.Provider. Load returns a configured
// instance or an error (e.g. missing env config); the SiteManager treats an
// error as "auth disabled for this site" and falls back to its default view.
type {{.TitleName}}Provider struct{}

// Name is the registry key a site references via AuthConfig.Provider.
func ({{.TitleName}}Provider) Name() string { return "{{.Name}}" }

// Load reads its credentials from the environment and returns a configured
// instance, or an error when they are incomplete. Replace this with your real
// auth flow.
func ({{.TitleName}}Provider) Load(cfg sdkauth.AuthConfig) (sdkauth.ProviderInstance, error) {
	if cfg.Provider == "" {
		return nil, errors.New("{{.Name}}: empty provider name")
	}
	return &{{.TitleName}}Instance{}, nil
}

// {{.TitleName}}Instance implements sdkauth.ProviderInstance.
// RegisterAuthRoutes mounts the auth web-flow routes; AuthMiddleware protects
// a site's group.
type {{.TitleName}}Instance struct{}

// RegisterAuthRoutes mounts the auth web-flow routes (e.g. /login,
// /callback). Replace this placeholder with your provider's OAuth flow.
func (e *{{.TitleName}}Instance) RegisterAuthRoutes(router gin.IRouter, _ *sessions.Store) {
	router.GET("/auth/{{.Name}}/login", func(c *gin.Context) {
		c.String(http.StatusOK, "{{.Name}} provider login (not implemented)")
	})
}

// AuthMiddleware protects a site's group. A real middleware checks the
// session and redirects to the login start endpoint when unauthenticated.
// This placeholder always allows.
func (e *{{.TitleName}}Instance) AuthMiddleware(_ *sessions.Store) gin.HandlerFunc {
	return func(c *gin.Context) {
		c.Next()
	}
}