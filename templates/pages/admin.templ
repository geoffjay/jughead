templ logsContent() {
	<div class="w-full p-8">
		<div class="mx-auto max-w-6xl space-y-6">
			@pageHeader("Logs", "Application and audit logs.")
			@emptyState("Logs")
		</div>
	</div>
}

// LogsContent renders the admin logs page using the AppShell container.
templ LogsContent() {
	@adminShell("/admin/logs", logsContent())
}
