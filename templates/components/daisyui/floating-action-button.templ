package daisyui

// FABTrigger describes the main focusable button of a FAB. It is rendered as
// a <div tabindex="0" role="button"> (a real <button> can't receive focus in
// Safari) with the daisyUI btn classes. Label is rendered as the button text;
// Children, when set, is rendered instead of Label (use for SVG icons). Color
// accepts the documented button color suffixes. Size defaults to "lg" when
// empty. Modifier defaults to "circle" when empty (pass "square" or "" to
// override). Class lets callers add extra utility classes.
type FABTrigger struct {
	Label    string
	Color    string
	Size     string
	Modifier string
	Class    string
	Children templ.Component
}

// FABItem describes a single action button shown when the FAB opens. Label,
// when set, is rendered as text before the button (wrapped in a <div>); Button
// is the action button component itself (typically a Button or raw markup).
type FABItem struct {
	Label  string
	Button templ.Component
}

// FABConfig configures a Floating Action Button / Speed Dial. Trigger is the
// focusable main button. CloseButton, when set, is rendered inside a
// .fab-close wrapper (a visual placeholder that closes the FAB on click — it
// must not be focusable). MainAction, when set, is rendered inside a
// .fab-main-action wrapper (replaces the trigger when the FAB is open). Items
// are the speed-dial buttons shown when the FAB opens. Flower adds the
// fab-flower class for a quarter-circle arrangement. Class lets callers add
// extra utility classes (e.g. positioning: "absolute z-1").
type FABConfig struct {
	Trigger     FABTrigger
	CloseButton templ.Component
	MainAction  templ.Component
	Items       []FABItem
	Flower      bool
	Class       string
}

// FAB renders a daisyUI Floating Action Button / Speed Dial.
templ FAB(cfg FABConfig) {
	<div class={ joinClasses("fab", fabFlowerClass(cfg.Flower), cfg.Class) }>
		if len(cfg.Items) == 0 && cfg.CloseButton == nil && cfg.MainAction == nil {
			<button class={ fabTriggerClass(cfg.Trigger) }>
				if cfg.Trigger.Children != nil {
					@cfg.Trigger.Children
				}
				{ cfg.Trigger.Label }
			</button>
		} else {
			<div tabindex="0" role="button" class={ fabTriggerClass(cfg.Trigger) }>
				if cfg.Trigger.Children != nil {
					@cfg.Trigger.Children
				}
				{ cfg.Trigger.Label }
			</div>
			if cfg.CloseButton != nil {
				<div class="fab-close">
					@cfg.CloseButton
				</div>
			}
			if cfg.MainAction != nil {
				<div class="fab-main-action">
					@cfg.MainAction
				</div>
			}
			for _, item := range cfg.Items {
				if item.Label != "" {
					<div>{ item.Label } @item.Button
</div>
				} else {
					@item.Button
				}
			}
		}
	</div>
}

func fabFlowerClass(flower bool) string {
	if flower {
		return "fab-flower"
	}
	return ""
}

func fabTriggerClass(t FABTrigger) string {
	size := t.Size
	if size == "" {
		size = "lg"
	}
	modifier := t.Modifier
	if modifier == "" {
		modifier = "circle"
	}
	return joinClasses(
		"btn",
		classFor("btn", t.Color),
		classFor("btn", size),
		classFor("btn", modifier),
		t.Class,
	)
}
