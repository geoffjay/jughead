			<h1 class="text-4xl font-bold text-primary">domain1.tld</h1>
			<p class="text-base-content/70">
				Reusable daisyUI component examples. Use the "Components" dropdown in
				the navbar to browse each component.
			</p>
			<ul class="menu bg-base-100 rounded-box w-56 shadow">
				<li>
					@daisyui.Link("/components/accordion", "Accordion", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/navbar", "Navbar", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/join", "Join", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/stack", "Stack", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/divider", "Divider", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/mask", "Mask", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/link", "Link", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/kbd", "Kbd", "", "hover", "", r)
				</li>
				<li>
