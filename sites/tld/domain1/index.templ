				</li>
				<li>
					@daisyui.Link("/components/collapse", "Collapse", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/swap", "Swap", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/theme-controller", "Theme Controller", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/button", "Button", "", "hover", "", r)
				</li>
				<li>
