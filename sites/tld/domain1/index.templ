				<li>
					@daisyui.Link("/components/radio", "Radio", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/range", "Range slider", "", "hover", "", r)
				</li>
				<li>
					@daisyui.Link("/components/file-input", "File Input", "", "hover", "", r)
