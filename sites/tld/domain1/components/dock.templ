package components

import (
	"github.com/geoffjay/jughead/sites/links"
	"github.com/geoffjay/jughead/templates/components/daisyui"
)

templ DockPage(r links.LinkResolver) {
	@pageShell(r, "Dock", "Dock is a fixed bar at the bottom of the screen for mobile navigation.", dockBody(r))
}

templ dockBody(r links.LinkResolver) {
	@section("Dock", `@daisyui.Dock(daisyui.DockConfig{
	Items: []daisyui.DockItem{
		{Label: "Home", Href: "#", Icon: dockHomeIcon(), Active: true},
		{Label: "Search", Href: "#", Icon: dockSearchIcon()},
		{Label: "Notifications", Href: "#", Icon: dockBellIcon()},
		{Label: "Profile", Href: "#", Icon: dockUserIcon()},
	},
	Resolver: r,
})`, daisyui.Dock(daisyui.DockConfig{
		Items: []daisyui.DockItem{
			{Label: "Home", Href: "#", Icon: dockHomeIcon(), Active: true},
			{Label: "Search", Href: "#", Icon: dockSearchIcon()},
			{Label: "Notifications", Href: "#", Icon: dockBellIcon()},
			{Label: "Profile", Href: "#", Icon: dockUserIcon()},
		},
		Resolver: r,
	}))
	@section("Dock with colored background", `@daisyui.Dock(daisyui.DockConfig{
	Items: []daisyui.DockItem{
		{Label: "Home", Href: "#", Icon: dockHomeIcon(), Active: true},
		{Label: "Wallet", Href: "#", Icon: dockWalletIcon()},
		{Label: "Stats", Href: "#", Icon: dockChartIcon()},
		{Label: "Profile", Href: "#", Icon: dockUserIcon()},
	},
	Class:    "bg-neutral text-neutral-content",
	Resolver: r,
})`, daisyui.Dock(daisyui.DockConfig{
		Items: []daisyui.DockItem{
			{Label: "Home", Href: "#", Icon: dockHomeIcon(), Active: true},
			{Label: "Wallet", Href: "#", Icon: dockWalletIcon()},
			{Label: "Stats", Href: "#", Icon: dockChartIcon()},
			{Label: "Profile", Href: "#", Icon: dockUserIcon()},
		},
		Class:    "bg-neutral text-neutral-content",
		Resolver: r,
	}))
	@section("Dock with buttons (no href)", `@daisyui.Dock(daisyui.DockConfig{
	Items: []daisyui.DockItem{
		{Label: "Play", Icon: dockPlayIcon(), Active: true},
		{Label: "Pause", Icon: dockPauseIcon()},
		{Label: "Stop", Icon: dockStopIcon()},
	},
})`, daisyui.Dock(daisyui.DockConfig{
		Items: []daisyui.DockItem{
			{Label: "Play", Icon: dockPlayIcon(), Active: true},
			{Label: "Pause", Icon: dockPauseIcon()},
			{Label: "Stop", Icon: dockStopIcon()},
		},
	}))
	@section("Dock sizes", `@daisyui.Dock(daisyui.DockConfig{
	Items: []daisyui.DockItem{
		{Icon: dockHomeIcon(), Href: "#", Active: true, Label: "XS"},
		{Icon: dockSearchIcon(), Href: "#", Label: "Tab"},
	},
	Size: "xs", Resolver: r,
})
// ... one per size (sm, lg, xl)`, dockSizes(r))
	@section("Dock without labels (icon-only)", `@daisyui.Dock(daisyui.DockConfig{
	Items: []daisyui.DockItem{
		{Icon: dockHomeIcon(), Href: "#", Active: true},
		{Icon: dockSearchIcon(), Href: "#"},
		{Icon: dockBellIcon(), Href: "#"},
		{Icon: dockUserIcon(), Href: "#"},
	},
	Class:    "bg-base-300",
	Resolver: r,
})`, daisyui.Dock(daisyui.DockConfig{
		Items: []daisyui.DockItem{
			{Icon: dockHomeIcon(), Href: "#", Active: true},
			{Icon: dockSearchIcon(), Href: "#"},
			{Icon: dockBellIcon(), Href: "#"},
			{Icon: dockUserIcon(), Href: "#"},
		},
		Class:    "bg-base-300",
		Resolver: r,
	}))
}

templ dockSizes(r links.LinkResolver) {
	<div class="flex flex-col gap-4">
		@daisyui.Dock(daisyui.DockConfig{
			Items: []daisyui.DockItem{
				{Icon: dockHomeIcon(), Href: "#", Active: true, Label: "XS"},
				{Icon: dockSearchIcon(), Href: "#", Label: "Tab"},
			},
			Size: "xs", Resolver: r,
		})
		@daisyui.Dock(daisyui.DockConfig{
			Items: []daisyui.DockItem{
				{Icon: dockHomeIcon(), Href: "#", Active: true, Label: "SM"},
				{Icon: dockSearchIcon(), Href: "#", Label: "Tab"},
			},
			Size: "sm", Resolver: r,
		})
		@daisyui.Dock(daisyui.DockConfig{
			Items: []daisyui.DockItem{
				{Icon: dockHomeIcon(), Href: "#", Active: true, Label: "LG"},
				{Icon: dockSearchIcon(), Href: "#", Label: "Tab"},
			},
			Size: "lg", Resolver: r,
		})
		@daisyui.Dock(daisyui.DockConfig{
			Items: []daisyui.DockItem{
				{Icon: dockHomeIcon(), Href: "#", Active: true, Label: "XL"},
				{Icon: dockSearchIcon(), Href: "#", Label: "Tab"},
			},
			Size: "xl", Resolver: r,
		})
	</div>
}

templ dockHomeIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
	</svg>
}

templ dockSearchIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
	</svg>
}

templ dockBellIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
	</svg>
}

templ dockUserIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
	</svg>
}

templ dockWalletIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
	</svg>
}

templ dockChartIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
	</svg>
}

templ dockPlayIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
		<path d="M8 5v14l11-7z"></path>
	</svg>
}

templ dockPauseIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
		<path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>
	</svg>
}

templ dockStopIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
		<path d="M6 6h12v12H6z"></path>
	</svg>
}
