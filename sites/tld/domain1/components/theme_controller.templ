package components

import (
	"github.com/geoffjay/jughead/sites/links"
	"github.com/geoffjay/jughead/templates/components/daisyui"
)

templ ThemeControllerPage(r links.LinkResolver) {
	@pageShell(r, "Theme Controller", "If a checked checkbox input or a checked radio input with theme-controller class exists in the page, The page will have the same theme as that input's value.", themeControllerBody(r))
}

templ themeControllerBody(r links.LinkResolver) {
	@section("Theme Controller using a toggle", `@daisyui.ThemeController(daisyui.ThemeControllerConfig{
	InputClass: "toggle",
	Value:      "synthwave",
})`, daisyui.ThemeController(daisyui.ThemeControllerConfig{
		InputClass: "toggle",
		Value:      "synthwave",
	}))
	@section("Theme Controller using a checkbox", `@daisyui.ThemeController(daisyui.ThemeControllerConfig{
	InputClass: "checkbox",
	Value:      "synthwave",
})`, daisyui.ThemeController(daisyui.ThemeControllerConfig{
		InputClass: "checkbox",
		Value:      "synthwave",
	}))
	@section("Theme Controller using a toggle with text", `<label class="flex cursor-pointer gap-2">
	<span class="label-text">Default</span>
	@daisyui.ThemeController(daisyui.ThemeControllerConfig{InputClass: "toggle", Value: "synthwave"})
	<span class="label-text">Synthwave</span>
</label>`, themeControllerToggleWithText())
	@section("Theme Controller using a toggle with icons", `<label class="flex cursor-pointer gap-2">
	<svg ...>...</svg>
	@daisyui.ThemeController(daisyui.ThemeControllerConfig{InputClass: "toggle", Value: "synthwave"})
	<svg ...>...</svg>
</label>`, themeControllerToggleWithIcons())
	@section("Theme Controller using a radio input", `<fieldset class="fieldset">
	<label class="flex gap-2 cursor-pointer items-center">
		@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "default"})
		Default
	</label>
	// ... one label per theme
</fieldset>`, themeControllerRadioInput())
	@section("Theme Controller using a radio button", `<div class="join join-vertical">
	<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Default" value="default"/>
	// ... one per theme
</div>`, themeControllerRadioButton())
}

templ themeControllerToggleWithText() {
	<label class="flex cursor-pointer gap-2">
		<span class="label-text">Default</span>
		@daisyui.ThemeController(daisyui.ThemeControllerConfig{InputClass: "toggle", Value: "synthwave"})
		<span class="label-text">Synthwave</span>
	</label>
}

templ themeControllerToggleWithIcons() {
	<label class="flex cursor-pointer gap-2">
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"></path></svg>
		@daisyui.ThemeController(daisyui.ThemeControllerConfig{InputClass: "toggle", Value: "synthwave"})
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
	</label>
}

templ themeControllerRadioInput() {
	<fieldset class="fieldset">
		<label class="flex gap-2 cursor-pointer items-center">
			@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "default"})
			Default
		</label>
		<label class="flex gap-2 cursor-pointer items-center">
			@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "retro"})
			Retro
		</label>
		<label class="flex gap-2 cursor-pointer items-center">
			@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "cyberpunk"})
			Cyberpunk
		</label>
		<label class="flex gap-2 cursor-pointer items-center">
			@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "valentine"})
			Valentine
		</label>
		<label class="flex gap-2 cursor-pointer items-center">
			@daisyui.ThemeController(daisyui.ThemeControllerConfig{AsRadio: true, Name: "theme-radios", InputClass: "radio radio-sm", Value: "aqua"})
			Aqua
		</label>
	</fieldset>
}

// themeControllerRadioButton uses raw inputs because the rendered button text
// comes from the aria-label attribute, which ThemeControllerConfig does not expose.
templ themeControllerRadioButton() {
	<div class="join join-vertical">
		<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Default" value="default"/>
		<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Retro" value="retro"/>
		<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Cyberpunk" value="cyberpunk"/>
		<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Valentine" value="valentine"/>
		<input type="radio" name="theme-buttons" autocomplete="off" class="btn theme-controller join-item" aria-label="Aqua" value="aqua"/>
	</div>
}
