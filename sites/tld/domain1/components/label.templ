package components

import (
	"github.com/geoffjay/jughead/sites/links"
	"github.com/geoffjay/jughead/templates/components/daisyui"
)

templ LabelPage(r links.LinkResolver) {
	@pageShell(r, "Label", "Label is used to provide a name or title for an input field. Label can be placed before or after the field.", labelBody(r))
}

templ labelBody(r links.LinkResolver) {
	@section("Label for input", `<label class="input">
	@daisyui.Label(daisyui.LabelConfig{Text: "https://"})
	<input type="text" placeholder="URL" />
</label>`, labelForInput())
	@section("Label for input at the end", `<label class="input">
	<input type="text" placeholder="domain name" />
	@daisyui.Label(daisyui.LabelConfig{Text: ".com"})
</label>`, labelForInputEnd())
	@section("Label for select", `<label class="select">
	@daisyui.Label(daisyui.LabelConfig{Text: "Type"})
	<select>
		<option>Personal</option>
		<option>Business</option>
	</select>
</label>`, labelForSelect())
	@section("Label for date input", `<label class="input">
	@daisyui.Label(daisyui.LabelConfig{Text: "Publish date"})
	<input type="date" />
</label>`, labelForDate())
	@section("Floating Label", `@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{
	Label:       "Your Email",
	InputType:   "email",
	Placeholder: "mail@site.com",
	InputClass:  "input input-md",
	Class:       "w-full max-w-xs",
})`, daisyui.FloatingLabel(daisyui.FloatingLabelConfig{
		Label:       "Your Email",
		InputType:   "email",
		Placeholder: "mail@site.com",
		InputClass:  "input input-md",
		Class:       "w-full max-w-xs",
	}))
	@section("Floating Label with Different Sizes", `<div class="grid gap-4 w-xs">
	@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Extra Small", Placeholder: "Extra Small", InputClass: "input input-xs"})
	@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Small", Placeholder: "Small", InputClass: "input input-sm"})
	// ... one per size
</div>`, floatingLabelSizeRow())
}

templ labelForInput() {
	<label class="input">
		@daisyui.Label(daisyui.LabelConfig{Text: "https://"})
		<input type="text" placeholder="URL"/>
	</label>
}

templ labelForInputEnd() {
	<label class="input">
		<input type="text" placeholder="domain name"/>
		@daisyui.Label(daisyui.LabelConfig{Text: ".com"})
	</label>
}

templ labelForSelect() {
	<label class="select">
		@daisyui.Label(daisyui.LabelConfig{Text: "Type"})
		<select>
			<option>Personal</option>
			<option>Business</option>
		</select>
	</label>
}

templ labelForDate() {
	<label class="input">
		@daisyui.Label(daisyui.LabelConfig{Text: "Publish date"})
		<input type="date"/>
	</label>
}

templ floatingLabelSizeRow() {
	<div class="grid gap-4 w-xs">
		@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Extra Small", Placeholder: "Extra Small", InputClass: "input input-xs"})
		@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Small", Placeholder: "Small", InputClass: "input input-sm"})
		@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Medium", Placeholder: "Medium", InputClass: "input input-md"})
		@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Large", Placeholder: "Large", InputClass: "input input-lg"})
		@daisyui.FloatingLabel(daisyui.FloatingLabelConfig{Label: "Extra Large", Placeholder: "Extra Large", InputClass: "input input-xl"})
	</div>
}
