	@section("Secondary color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "secondary"}))
	@section("Accent color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "accent"}))
	@section("Success color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "success"}))
	@section("Warning color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "warning"}))
	@section("Info color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "info"}))
	@section("Error color", daisyui.Range(daisyui.RangeConfig{Min: "0", Max: "100", Value: "40", Color: "error"}))
