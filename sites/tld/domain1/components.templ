templ badgeIconRow() {
	<div class="flex flex-wrap gap-2">
		@daisyui.Badge(daisyui.BadgeConfig{
			Color:    "info",
			Children: templ.Raw(`<svg class="size-[1em]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><g fill="currentColor" stroke-linejoin="miter" stroke-linecap="butt"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-linecap="square" stroke-miterlimit="10" stroke-width="2"></circle><path d="m12,17v-5.5c0-.276-.224-.5-.5-.5h-1.5" fill="none" stroke="currentColor" stroke-linecap="square" stroke-miterlimit="10" stroke-width="2"></path><circle cx="12" cy="7.25" r="1.25" fill="currentColor" stroke-width="2"></circle></g></svg>Info`),
		})
		@daisyui.Badge(daisyui.BadgeConfig{
			Color:    "success",
			Children: templ.Raw(`<svg class="size-[1em]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><g fill="currentColor" stroke-linejoin="miter" stroke-linecap="butt"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-linecap="square" stroke-miterlimit="10" stroke-width="2"></circle><polyline points="7 13 10 16 17 8" fill="none" stroke="currentColor" stroke-linecap="square" stroke-miterlimit="10" stroke-width="2"></polyline></g></svg>Success`),
		})
	</div>
}

templ ProgressPage(r links.LinkResolver) {
	@pageShell(r, "Progress", "Progress bar can be used to show the progress of a task or to show the passing of time.", progressBody(r))
}

templ progressBody(r links.LinkResolver) {
	@section("Progress", templ.Raw(`
		<div class="flex flex-col gap-2 items-center">
			<progress class="progress w-56" value="0" max="100"></progress>
			<progress class="progress w-56" value="10" max="100"></progress>
			<progress class="progress w-56" value="40" max="100"></progress>
			<progress class="progress w-56" value="70" max="100"></progress>
			<progress class="progress w-56" value="100" max="100"></progress>
		</div>`))
	@section("Primary color", progressColorRow("primary"))
	@section("Secondary color", progressColorRow("secondary"))
	@section("Accent color", progressColorRow("accent"))
	@section("Neutral color", progressColorRow("neutral"))
	@section("Info color", progressColorRow("info"))
	@section("Success color", progressColorRow("success"))
	@section("Warning color", progressColorRow("warning"))
	@section("Error color", progressColorRow("error"))
	@section("Indeterminate (without value)", daisyui.Progress(daisyui.ProgressConfig{Class: "w-56"}))
}

templ progressColorRow(color string) {
	<div class="flex flex-col gap-2 items-center">
		@daisyui.Progress(daisyui.ProgressConfig{Value: "0", Max: "100", Color: color, Class: "w-56"})
		@daisyui.Progress(daisyui.ProgressConfig{Value: "10", Max: "100", Color: color, Class: "w-56"})
		@daisyui.Progress(daisyui.ProgressConfig{Value: "40", Max: "100", Color: color, Class: "w-56"})
		@daisyui.Progress(daisyui.ProgressConfig{Value: "70", Max: "100", Color: color, Class: "w-56"})
		@daisyui.Progress(daisyui.ProgressConfig{Value: "100", Max: "100", Color: color, Class: "w-56"})
	</div>
}

templ RadialProgressPage(r links.LinkResolver) {
	@pageShell(r, "Radial progress", "Radial progress can be used to show the progress of a task or to show the passing of time.", radialProgressBody(r))
}

templ radialProgressBody(r links.LinkResolver) {
	@section("Radial progress", daisyui.RadialProgress(daisyui.RadialProgressConfig{
		Value: "70", Label: "70%",
	}))
	@section("Different values", templ.Raw(`
		<div class="flex gap-4">
			<div class="radial-progress" style="--value:0;" aria-valuenow="0" role="progressbar">0%</div>
			<div class="radial-progress" style="--value:20;" aria-valuenow="20" role="progressbar">20%</div>
			<div class="radial-progress" style="--value:60;" aria-valuenow="60" role="progressbar">60%</div>
			<div class="radial-progress" style="--value:80;" aria-valuenow="80" role="progressbar">80%</div>
			<div class="radial-progress" style="--value:100;" aria-valuenow="100" role="progressbar">100%</div>
		</div>`))
	@section("Custom color", daisyui.RadialProgress(daisyui.RadialProgressConfig{
		Value: "70", Label: "70%", ColorClass: "text-primary",
	}))
	@section("With background color and border", daisyui.RadialProgress(daisyui.RadialProgressConfig{
		Value: "70", Label: "70%",
		Class: "bg-primary text-primary-content border-4 border-primary",
	}))
	@section("Custom size and custom thickness", templ.Raw(`
		<div class="flex gap-4">
			<div class="radial-progress" style="--value:70; --size:12rem; --thickness: 2px;" aria-valuenow="70" role="progressbar">70%</div>
			<div class="radial-progress" style="--value:70; --size:12rem; --thickness: 2rem;" aria-valuenow="70" role="progressbar">70%</div>
		</div>`))
}

