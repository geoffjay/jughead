	}))
	@section("indicator-top (default) indicator-end (default)", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-middle indicator-start", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "start", Vertical: "middle", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-middle indicator-center", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "center", Vertical: "middle", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-middle indicator-end (default)", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Vertical: "middle", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-bottom indicator-start", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "start", Vertical: "bottom", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-bottom indicator-center", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "center", Vertical: "bottom", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("indicator-bottom indicator-end (default)", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Vertical: "bottom", Class: "badge badge-secondary"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 bg-base-300 place-items-center">content</div>`),
	}))
	@section("multiple indicators", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "start", Vertical: "top", Class: "badge", Children: templ.Raw("↖︎")},
			{Horizontal: "center", Vertical: "top", Class: "badge", Children: templ.Raw("↑")},
			{Class: "badge", Children: templ.Raw("↗︎")},
			{Horizontal: "start", Vertical: "middle", Class: "badge", Children: templ.Raw("←")},
			{Horizontal: "center", Vertical: "middle", Class: "badge", Children: templ.Raw("●")},
			{Vertical: "middle", Class: "badge", Children: templ.Raw("→")},
			{Horizontal: "start", Vertical: "bottom", Class: "badge", Children: templ.Raw("↙︎")},
			{Horizontal: "center", Vertical: "bottom", Class: "badge", Children: templ.Raw("↓")},
			{Vertical: "bottom", Class: "badge", Children: templ.Raw("↘︎")},
		},
		Children: templ.Raw(`<div class="grid w-60 h-32 bg-base-300 place-items-center">Box</div>`),
	}))
	@section("Responsive", daisyui.Indicator(daisyui.IndicatorConfig{
		Items: []daisyui.IndicatorItemConfig{
			{Horizontal: "start", Class: "badge badge-secondary indicator-start sm:indicator-middle md:indicator-bottom lg:indicator-center xl:indicator-end"},
		},
		Children: templ.Raw(`<div class="grid w-32 h-32 rounded bg-base-300 place-items-center">content</div>`),
	}))
}

templ ChatBubblePage(r links.LinkResolver) {
	@pageShell(r, "Chat bubble", "Chat bubbles are used to show one line of conversation and all its data, including the author image, author name, time, etc.", chatBubbleBody(r))
}

templ chatBubbleBody(r links.LinkResolver) {
	@section("chat-start and chat-end", templ.Raw(`
		<div class="w-full">
			<div class="chat chat-start">
				<div class="chat-bubble">It's over Anakin, <br/>I have the high ground.</div>
			</div>
			<div class="chat chat-end">
				<div class="chat-bubble">You underestimate my power!</div>
			</div>
		</div>`))
	@section("Chat with image", templ.Raw(`
		<div class="w-full">
			<div class="chat chat-start">
				<div class="chat-image avatar">
					<div class="w-10 rounded-full">
						<img alt="Tailwind CSS chat bubble component" src="https://img.daisyui.com/images/profile/demo/kenobee@192.webp" />
					</div>
				</div>
				<div class="chat-bubble">It was said that you would, destroy the Sith, not join them.</div>
			</div>
			<div class="chat chat-start">
				<div class="chat-image avatar">
					<div class="w-10 rounded-full">
						<img alt="Tailwind CSS chat bubble component" src="https://img.daisyui.com/images/profile/demo/kenobee@192.webp" />
					</div>
				</div>
				<div class="chat-bubble">It was you who would bring balance to the Force</div>
			</div>
			<div class="chat chat-start">
				<div class="chat-image avatar">
					<div class="w-10 rounded-full">
						<img alt="Tailwind CSS chat bubble component" src="https://img.daisyui.com/images/profile/demo/kenobee@192.webp" />
					</div>
				</div>
				<div class="chat-bubble">Not leave it in Darkness</div>
			</div>
		</div>`))
	@section("Chat with image, header and footer", templ.Raw(`
		<div class="w-full">
			<div class="chat chat-start">
				<div class="chat-image avatar">
					<div class="w-10 rounded-full">
						<img alt="Tailwind CSS chat bubble component" src="https://img.daisyui.com/images/profile/demo/kenobee@192.webp" />
					</div>
				</div>
				<div class="chat-header">
					Obi-Wan Kenobi
					<time class="text-xs opacity-50">12:45</time>
				</div>
				<div class="chat-bubble">You were the Chosen One!</div>
				<div class="chat-footer opacity-50">Delivered</div>
			</div>
			<div class="chat chat-end">
				<div class="chat-image avatar">
					<div class="w-10 rounded-full">
						<img alt="Tailwind CSS chat bubble component" src="https://img.daisyui.com/images/profile/demo/anakeen@192.webp" />
					</div>
				</div>
				<div class="chat-header">
					Anakin
					<time class="text-xs opacity-50">12:46</time>
				</div>
				<div class="chat-bubble">I hate you!</div>
				<div class="chat-footer opacity-50">Seen at 12:46</div>
			</div>
		</div>`))
	@section("Chat with header and footer", templ.Raw(`
		<div class="w-full">
			<div class="chat chat-start">
				<div class="chat-header">
					Obi-Wan Kenobi
					<time class="text-xs opacity-50">2 hours ago</time>
				</div>
				<div class="chat-bubble">You were my brother, Anakin.</div>
				<div class="chat-footer opacity-50">Seen</div>
			</div>
			<div class="chat chat-start">
				<div class="chat-header">
					Obi-Wan Kenobi
					<time class="text-xs opacity-50">2 hour ago</time>
				</div>
				<div class="chat-bubble">I loved you.</div>
				<div class="chat-footer opacity-50">Delivered</div>
			</div>
		</div>`))
	@section("Chat Bubble with colors", chatBubbleColorsRow())
}

templ chatBubbleColorsRow() {
	<div class="w-full">
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{Color: "primary", Message: "What kind of nonsense is this"})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{Color: "secondary", Message: "Put me on the Council and not make me a Master!??"})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{Color: "accent", Message: "That's never been done in the history of the Jedi."})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{Color: "neutral", Message: "It's insulting!"})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{End: true, Color: "info", Message: "Calm down, Anakin."})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{End: true, Color: "success", Message: "You have been given a great honor."})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{End: true, Color: "warning", Message: "To be on the Council at your age."})
		@daisyui.ChatBubble(daisyui.ChatBubbleConfig{End: true, Color: "error", Message: "It's never happened before."})
	</div>
}
