templ ratingSizeRow() {
	<div class="flex flex-col gap-2 items-center">
		@daisyui.Rating(daisyui.RatingConfig{Name: "rating-5", Size: "xs", Items: ratingStarItems("rating-5", "bg-orange-400", 2)})
		@daisyui.Rating(daisyui.RatingConfig{Name: "rating-6", Size: "sm", Items: ratingStarItems("rating-6", "bg-orange-400", 2)})
		@daisyui.Rating(daisyui.RatingConfig{Name: "rating-7", Size: "md", Items: ratingStarItems("rating-7", "bg-orange-400", 2)})
		@daisyui.Rating(daisyui.RatingConfig{Name: "rating-8", Size: "lg", Items: ratingStarItems("rating-8", "bg-orange-400", 2)})
		@daisyui.Rating(daisyui.RatingConfig{Name: "rating-9", Size: "xl", Items: ratingStarItems("rating-9", "bg-orange-400", 2)})
	</div>
}

// ratingStarItems builds a 5-star rating item slice using mask-star-2 and the
// given background color class, marking the item at checkedIndex (1-based) as
// checked.
func ratingStarItems(name, colorClass string, checkedIndex int) []daisyui.RatingItem {
	items := make([]daisyui.RatingItem, 5)
	for i := 0; i < 5; i++ {
		items[i] = daisyui.RatingItem{
			Mask:       "star-2",
			ColorClass: colorClass,
			AriaLabel:  starAriaLabel(i + 1),
			Checked:    (i + 1) == checkedIndex,
		}
	}
	return items
}

func starAriaLabel(n int) string {
	switch n {
	case 1:
		return "1 star"
	case 2:
		return "2 star"
	case 3:
		return "3 star"
	case 4:
		return "4 star"
	default:
		return "5 star"
	}
}

