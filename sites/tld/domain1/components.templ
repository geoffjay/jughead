templ SelectPage(r links.LinkResolver) {
	@pageShell(r, "Select", "Select is used to pick a value from a list of options.", selectBody(r))
}

templ selectBody(r links.LinkResolver) {
	@section("Select", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a color",
		Options: []daisyui.SelectOption{
			{Value: "Crimson"},
			{Value: "Amber"},
			{Value: "Velvet"},
		},
	}))
	@section("Ghost (no background)", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a font",
		Style:       "ghost",
		Options: []daisyui.SelectOption{
			{Value: "Inter"},
			{Value: "Poppins"},
			{Value: "Raleway"},
		},
	}))
	@section("With fieldset and labels", daisyui.Fieldset(daisyui.FieldsetConfig{
		Legend: "Browsers",
		Class:  "w-xs",
	}, templ.Raw(`
		<select class="select">
			<option disabled selected>Pick a Browser</option>
			<option>Chrome</option>
			<option>FireFox</option>
			<option>Safari</option>
		</select>
		<span class="label">Optional</span>`)))
	@section("Primary color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a text editor",
		Color:       "primary",
		Options: []daisyui.SelectOption{
			{Value: "VScode"},
			{Value: "VScode fork"},
			{Value: "Another VScode fork"},
		},
	}))
	@section("Secondary color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a language",
		Color:       "secondary",
		Options: []daisyui.SelectOption{
			{Value: "Zig"},
			{Value: "Go"},
			{Value: "Rust"},
		},
	}))
	@section("Accent color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Color scheme",
		Color:       "accent",
		Options: []daisyui.SelectOption{
			{Value: "Light mode"},
			{Value: "Dark mode"},
			{Value: "System"},
		},
	}))
	@section("Neutral color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Server location",
		Color:       "neutral",
		Options: []daisyui.SelectOption{
			{Value: "North America"},
			{Value: "EU west"},
			{Value: "South East Asia"},
		},
	}))
	@section("Info color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a Framework",
		Color:       "info",
		Options: []daisyui.SelectOption{
			{Value: "React"},
			{Value: "Vue"},
			{Value: "Angular"},
		},
	}))
	@section("Success color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a Runtime",
		Color:       "success",
		Options: []daisyui.SelectOption{
			{Value: "npm"},
			{Value: "Bun"},
			{Value: "yarn"},
		},
	}))
	@section("Warning color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick an OS",
		Color:       "warning",
		Options: []daisyui.SelectOption{
			{Value: "Windows"},
			{Value: "MacOS"},
			{Value: "Linux"},
		},
	}))
	@section("Error color", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick an AI Model",
		Color:       "error",
		Options: []daisyui.SelectOption{
			{Value: "GPT-4"},
			{Value: "Claude"},
			{Value: "Llama"},
		},
	}))
	@section("Sizes", selectSizeRow())
	@section("Disabled", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "You can't touch this",
		Disabled:    true,
	}))
	@section("Using OS native style for the options dropdown", daisyui.Select(daisyui.SelectConfig{
		Placeholder: "Pick a color",
		Class:       "appearance-none",
		Options: []daisyui.SelectOption{
			{Value: "Crimson"},
			{Value: "Amber"},
			{Value: "Velvet"},
		},
	}))
}

